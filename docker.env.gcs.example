# GCS/remote defaults for Docker runs
# Copy to docker.env and adjust as needed for GCS/BigQuery usage.
# For local sample runs, use docker.env.local.example -> docker.env.local.

# GCP Project Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Environment (dev/prod)
PIPELINE_ENV=dev
OBSERVABILITY_ENV=dev

# GCP Authentication
# Option 1: Application Default Credentials (ADC) - Recommended for local dev
# Uses your personal gcloud credentials mounted via docker-compose volumes
USE_SA_AUTH=false
CLOUDSDK_CONFIG=/home/airflow/.config/gcloud

# Option 2: Service Account Key (uncomment if using SA instead of ADC)
# USE_SA_AUTH=true
# GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/.gcp/sa.json
# GCP_SA_KEY_PATH=/path/to/your/local/service-account-key.json

# Observability Buckets
METRICS_BUCKET=your-metrics-bucket
LOGS_BUCKET=your-logs-bucket
REPORTS_BUCKET=your-reports-bucket

# Data Lake Paths (GCS)
BRONZE_BASE_PATH=gs://your-bronze-bucket/ecom/raw
SILVER_BASE_PATH=gs://your-silver-bucket/data/silver/base
SILVER_ENRICHED_PATH=gs://your-silver-bucket/data/silver/enriched
SILVER_DIMS_PATH=gs://your-silver-bucket/data/silver/dims

# Pipeline Configuration
SILVER_PUBLISH_MODE=staging
ENRICHED_PUBLISH_MODE=staging
DIMS_PUBLISH_MODE=staging
# Backfill behavior (off by default; opt-in for earliest-partition bootstrap)
DIMS_SNAPSHOT_ALLOW_BOOTSTRAP=false
