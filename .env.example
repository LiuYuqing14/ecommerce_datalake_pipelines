# ============================================================================
# Airflow User Configuration
# ============================================================================
# AIRFLOW_USERNAME=airflow
# AIRFLOW_PASSWORD=airflow
# AIRFLOW_EMAIL=airflow@example.com
# AIRFLOW__CORE__FERNET_KEY=changeme-generate-with-openssl-rand-base64-32

# ============================================================================
# Pipeline Environment
# ============================================================================
# Environment: local, dev, or prod
PIPELINE_ENV=local
OBSERVABILITY_ENV=local

# Publish Modes (direct=immediate, staging=validate-then-promote)
# SILVER_PUBLISH_MODE=direct
# ENRICHED_PUBLISH_MODE=direct
# DIMS_PUBLISH_MODE=direct


# ----------------------------------------------------------------------------
# Presets (uncomment to use)
# ----------------------------------------------------------------------------
# Dev (GCS + ADC)
# PIPELINE_ENV=dev
# METRICS_BUCKET=your-metrics-bucket
# REPORTS_BUCKET=your-reports-bucket
# LOGS_BUCKET=your-logs-bucket
# BRONZE_BASE_PATH=gs://your-bronze-bucket/ecom/raw
# SILVER_BASE_PATH=gs://your-silver-bucket/data/silver/base

# ============================================================================
# GCP Configuration (optional - only needed for prod/dev with GCS/BigQuery)
# ============================================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project
BQ_LOCATION=US
BQ_LOAD_ENABLED=false
# BQ_GOLD_DATASET=gold_marts

# ============================================================================
# Airflow Secrets Backend (optional - for prod with Secret Manager)
# ============================================================================
# AIRFLOW__SECRETS__BACKEND=airflow.providers.google.cloud.secrets.secret_manager.CloudSecretManagerBackend
# AIRFLOW__SECRETS__BACKEND_KWARGS={"connections_prefix":"airflow-connections","variables_prefix":"airflow-variables"}
