# Local dev defaults (sample data + local outputs)
# Copy to docker.env.local and run:
#   DOCKER_ENV_FILE=docker.env.local docker compose up -d --no-build

# Local pipeline mode
PIPELINE_ENV=local
OBSERVABILITY_ENV=local

# Local sample inputs (mounted at /opt/airflow/samples)
BRONZE_BASE_PATH=/opt/airflow/samples/bronze

# Local outputs (named volume at /opt/airflow/data)
SILVER_BASE_PATH=/opt/airflow/data/silver/base
SILVER_ENRICHED_PATH=/opt/airflow/data/silver/enriched
SILVER_DIMS_PATH=/opt/airflow/data/silver/dims

# Publish modes (direct for local)
SILVER_PUBLISH_MODE=direct
ENRICHED_PUBLISH_MODE=direct
DIMS_PUBLISH_MODE=direct

# Backfill behavior (off by default; opt-in for earliest-partition bootstrap)
DIMS_SNAPSHOT_ALLOW_BOOTSTRAP=false

# Optional: leave blank for local-only metrics/logs
METRICS_BUCKET=
LOGS_BUCKET=
REPORTS_BUCKET=

# GCP auth not required for local sample runs
USE_SA_AUTH=false
CLOUDSDK_CONFIG=/home/airflow/.config/gcloud
